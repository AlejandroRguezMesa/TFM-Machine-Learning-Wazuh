# Credenciales del Wazuh Indexer.
# Copiar este fichero a .env, rellenar la contrasena y aplicar permisos:
#     cp .env.example .env && nano .env && chmod 600 .env
# El fichero .env NO debe subirse a control de versiones.
WAZUH_INDEXER_HOST=localhost
WAZUH_INDEXER_PORT=9200
WAZUH_INDEXER_USER=tfm_analyst
WAZUH_INDEXER_PASS=CAMBIAR_ESTA_CONTRASENA
